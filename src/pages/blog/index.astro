---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { blogPage } from "../../config";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featured = sorted.find((p) => p.data.featured);
const rest = sorted.filter((p) => !p.data.featured);
---

<BaseLayout title="Blog" description={blogPage.subtitle}>
  <div class="blog-hero content-container">
    <h1>{blogPage.title}</h1>
    <p>{blogPage.subtitle}</p>
  </div>

  <div class="blog-feed">
    {featured && (
      <BlogCard
        variant="featured"
        title={featured.data.title}
        excerpt={featured.data.excerpt}
        href={`/blog/${featured.id.replace(/\.md$/, "")}`}
      />
    )}

    {rest.map((post) => (
      <BlogCard
        title={post.data.title}
        date={post.data.date}
        href={`/blog/${post.id.replace(/\.md$/, "")}`}
      />
    ))}

    {sorted.length === 0 && (
      <p style="color: var(--color-text-muted); text-align: center; padding: 3rem 0;">
        No posts yet. Check back soon.
      </p>
    )}
  </div>

  <div class="blog-cta content-container">
    <p>Subscribe via <a href="/rss.xml">RSS</a> to get notified of new posts.</p>
  </div>
</BaseLayout>
