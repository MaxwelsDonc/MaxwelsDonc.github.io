<nav class="blog-toc" aria-label="Table of contents">
  <div class="blog-toc-title">On this page</div>
  <ul class="blog-toc-list" id="toc-list"></ul>
</nav>

<script>
  (function () {
    const toc = document.getElementById("toc-list");
    const headings = document.querySelectorAll(".article-body h2, .article-body h3");
    if (!toc || headings.length === 0) return;

    headings.forEach((h, i) => {
      const id = h.id || `heading-${i}`;
      if (!h.id) h.id = id;

      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = `#${id}`;
      a.textContent = h.textContent || "";
      a.className = h.tagName === "H3" ? "blog-toc-sub" : "";
      li.appendChild(a);
      toc.appendChild(li);
    });

    // Highlight current heading on scroll
    const links = toc.querySelectorAll("a");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = toc.querySelector(`a[href="#${id}"]`);
          if (link && entry.isIntersecting) {
            links.forEach((l) => l.classList.remove("blog-toc-active"));
            link.classList.add("blog-toc-active");
          }
        });
      },
      { rootMargin: "-80px 0px -80% 0px" }
    );
    headings.forEach((h) => observer.observe(h));
  })();
</script>
