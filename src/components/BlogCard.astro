---
export interface Props {
  variant?: "featured" | "standard";
  title: string;
  date?: Date;
  excerpt?: string;
  href: string;
}
const { variant = "standard", title, date, excerpt, href } = Astro.props;

const formattedDate = date
  ? date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
  : null;
---

{variant === "featured" ? (
  <a href={href} class="blog-card-featured">
    <span class="featured-label">Featured</span>
    <h2>{title}</h2>
    {excerpt && <p>{excerpt}</p>}
  </a>
) : (
  <a href={href} class="blog-card">
    {formattedDate && <div class="blog-card-date">{formattedDate}</div>}
    <span class="blog-card-title">{title}</span>
  </a>
)}
